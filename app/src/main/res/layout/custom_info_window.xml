<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="150dp"
    android:maxWidth="260dp"
    android:background="@drawable/info_window_background"
    android:orientation="vertical"
    android:elevation="8dp"
    android:padding="12dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/bubble_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#2196F3"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#44FFFFFF"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/bubble_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#EEEEEE"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:gravity="center" />

    <ImageButton android:id="@+id/bubble_more" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/bubble_subline" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
</LinearLayout>