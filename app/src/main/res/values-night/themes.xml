<!-- res/values-night/themes.xml -->
<resources>
    <!-- Base application theme for dark mode -->
    <style name="Theme.GPSTracker" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Εδώ μπορούμε να προσθέσουμε σκούρο windowBackground αν θέλουμε -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#25283D</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Splash Screen Theme for dark mode -->
    <style name="Theme.GPSTracker.Splash" parent="Theme.GPSTracker">
        <!-- Ειδική ρύθμιση για το splash screen στο dark mode -->
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@drawable/gps1</item>
    </style>
</resources>